{{> partials/header title="Subscription Renewal Reminder" }}

<div style="background: linear-gradient(135deg, #1d4ed8 0%, #2563eb 100%); color: white; padding: 30px; text-align: center; border-radius: 10px 10px 0 0;">
  <h1 style="margin: 0; font-size: 28px;">Subscription Renewal Reminder</h1>
  <p style="margin: 10px 0 0 0; font-size: 16px;">Please ensure your payment method is active.</p>
</div>

<div style="background: #f9fafb; padding: 30px; border-radius: 0 0 10px 10px;">
  <p style="margin: 0 0 20px 0; font-size: 16px;">Hi {{name}},</p>

  <div style="background: #eff6ff; border: 1px solid #bfdbfe; padding: 20px; border-radius: 8px; margin: 20px 0;">
    {{#if (eq days_left 0)}}
    <p style="margin: 0 0 10px 0; color: #1e3a8a;">
      Your <strong>{{plan_name}}</strong> subscription renews <strong>today</strong> ({{renewal_date}}).
    </p>
    {{else}}
    <p style="margin: 0 0 10px 0; color: #1e3a8a;">
      Your <strong>{{plan_name}}</strong> subscription renews in <strong>{{days_left}} days</strong> ({{renewal_date}}).
    </p>
    {{/if}}
    <p style="margin: 0; color: #1e3a8a;">
      To avoid service interruption, please verify that your payment method has enough balance and is up to date.
    </p>
  </div>

  <div style="text-align: center; margin: 30px 0;">
    <a href="{{NEXT_PUBLIC_APP_URL}}/user/subscription" style="display: inline-block; background: #2563eb; color: white; padding: 12px 28px; text-decoration: none; border-radius: 6px; font-weight: 600;">
      Review Subscription
    </a>
  </div>

  <p style="margin: 20px 0; font-size: 16px;">
    If payment fails during renewal, your access may be affected until the payment method issue is resolved.
  </p>
  <p style="margin: 20px 0; font-size: 16px;">Need help? Contact support and we will assist you.</p>
  <p style="margin: 20px 0; font-size: 16px;">Best regards,<br>The Qurieus Team</p>
</div>

{{> partials/footer }}
