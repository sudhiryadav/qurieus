{{> partials/header}}
<div class="content" style="background: #fff; padding: 32px 24px; border: 1px solid #e9ecef; border-radius: 8px; max-width: 600px; margin: 0 auto;">
  <h2 style="color: #1a202c; margin-bottom: 16px;">Verify your email address</h2>
  <p style="font-size: 1.1rem; color: #333; margin-bottom: 24px;">Thank you for signing up! Please use the following code to verify your email address:</p>
  <div style="background: #f4f4f4; padding: 24px; text-align: center; font-size: 2rem; letter-spacing: 8px; border-radius: 8px; font-weight: bold; color: #007bff; margin-bottom: 24px;">
    {{code}}
  </div>
  <p style="color: #555;">This code will expire in 24 hours. If you didn't request this verification, please ignore this email.</p>
</div>
{{> partials/footer}} 