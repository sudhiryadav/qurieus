{{> partials/header}}

<div style="max-width: 600px; margin: 0 auto; padding: 20px; font-family: Arial, sans-serif;">
  <div style="text-align: center; margin-bottom: 30px;">
    <img src="{{logoUrl}}" alt="Qurieus Logo" style="height: 50px;">
  </div>

  <div style="background-color: #f8f9fa; padding: 30px; border-radius: 10px; margin-bottom: 20px;">
    <h1 style="color: #333; margin-bottom: 20px; font-size: 24px;">Chat Session Resolved</h1>
    
    <p style="color: #666; line-height: 1.6; margin-bottom: 20px;">
      Hi there! Your chat session has been marked as resolved. We hope we were able to provide you with the assistance you needed.
    </p>

    <div style="background-color: #e8f5e8; padding: 20px; border-radius: 8px; border-left: 4px solid #4caf50; margin-bottom: 20px;">
      <h3 style="color: #2e7d32; margin-bottom: 10px; font-size: 18px;">Session Details</h3>
      <ul style="color: #666; line-height: 1.6; margin: 0; padding-left: 20px;">
        <li><strong>Chat ID:</strong> {{chatId}}</li>
        <li><strong>Resolved by:</strong> {{agentName}}</li>
        <li><strong>Resolution time:</strong> {{resolvedAt}}</li>
        {{#if resolutionNotes}}
        <li><strong>Notes:</strong> {{resolutionNotes}}</li>
        {{/if}}
      </ul>
    </div>

    <p style="color: #666; line-height: 1.6; margin-bottom: 20px;">
      If you have any follow-up questions or need further assistance, please don't hesitate to start a new chat session. We're here to help!
    </p>

    <div style="text-align: center; margin-top: 30px;">
      <a href="{{chatUrl}}" style="background-color: #007bff; color: white; padding: 12px 24px; text-decoration: none; border-radius: 6px; display: inline-block; font-weight: 500;">
        Start New Chat
      </a>
    </div>
  </div>

  <div style="text-align: center; margin-top: 30px;">
    <p style="color: #999; font-size: 14px;">
      Thank you for using Qurieus. We appreciate your business!
    </p>
  </div>
</div>

{{> partials/footer}} 