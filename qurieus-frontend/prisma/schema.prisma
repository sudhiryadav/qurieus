// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

datasource db {
  provider          = "postgresql"
  url               = env("DATABASE_URL")
  shadowDatabaseUrl = env("SHADOW_DATABASE_URL") // Only needed when using a cloud provider that doesn't support the creation of new databases, like Heroku. Learn more: https://pris.ly/d/migrate-shadow
  extensions        = [vector]
}

generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
  previewFeatures = ["postgresqlExtensions"]
}

// Enums
enum SubscriptionType {
  TRIAL
  MONTHLY
  YEARLY
}

enum PlanType {
  FREE
  BASIC
  STANDARD
  PRO
  ENTERPRISE
}

enum UserRole {
  USER        @map("User")        /// Regular user with basic access
  ADMIN       @map("Admin")       /// Administrator with elevated privileges
  SUPER_ADMIN @map("Super Admin") /// Super administrator with full system access
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id                    String    @id @default(cuid())
  name                  String
  email                 String    @unique
  emailVerified         DateTime?
  image                 String?
  password              String
  passwordResetToken    String?   @unique
  passwordResetTokenExp DateTime?
  role                  UserRole  @default(USER)
  
  // Profile fields
  company               String?
  plan                  PlanType?
  subscription_type     SubscriptionType?
  subscription_start_date DateTime? @default(now())
  subscription_end_date DateTime?
  is_active             Boolean   @default(true)
  is_verified           Boolean   @default(false)
  verification_token    String?   @unique
  verification_expires  DateTime?
  login_attempts        Int       @default(0)
  locked_until          DateTime?
  created_at            DateTime  @default(now())
  updated_at            DateTime  @updatedAt
  jobTitle              String?
  bio                   String?
  phone                 String?
  
  accounts              Account[]
  sessions              Session[]
  subscription          Subscription?
  messages              Message[]
  documents             Document[]
  embeddings            Embedding[]
  chatConversations     ChatConversation[]
  logs                  Log[]
  queries               QueryAnalytics[]
  visitorSessions       VisitorSession[]

  allowedOrigins        String[] // e.g. ["https://mydomain.com"]
  allowedReferrers      String[] // e.g. ["https://mydomain.com/page"]
  allowedIPs            String[] // e.g. ["1.2.3.4"]
  @@map("Users")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model SubscriptionPlan {
  id          String   @id @default(cuid())
  name        String   @unique
  description String
  price       Float
  currency    String   @default("INR")
  features    String[]
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  subscriptions Subscription[]
  paddleConfig PaddleConfig?
  idealFor    String   // NEW: e.g. "Individuals", "Small Teams"
  keyLimits   String   // NEW: e.g. "5 docs · 10 MB · 25 queries/day"
  maxDocs     Int?
  maxStorageMB Int?
  maxQueriesPerDay Int?
}

model PaddleConfig {
  id                String   @id @default(cuid())
  subscriptionPlanId String  @unique
  productId         String
  priceId           String
  trialDays         Int      @default(0)
  billingCycle      String   @default("monthly")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  subscriptionPlan  SubscriptionPlan @relation(fields: [subscriptionPlanId], references: [id], onDelete: Cascade)
}

model Subscription {
  id                    String   @id @default(cuid())
  userId                String   @unique
  user                  User    @relation(fields: [userId], references: [id])
  planId                String
  plan                  SubscriptionPlan @relation(fields: [planId], references: [id])
  paddleSubscriptionId  String   @unique
  paddleCustomerId      String
  status                String
  currentPeriodStart    DateTime
  currentPeriodEnd      DateTime
  cancelledAt           DateTime?
  paddlePaymentId       String?
  paddlePaymentAmount   Float?
  paddlePaymentDate     DateTime?
  paddlePaymentError    String?
  paddlePaymentCurrency String?   @default("INR")
  startDate             DateTime @default(now())
  nextBillingDate       DateTime @default(now())
  createdAt             DateTime @default(now())
  billingCycle          String @default("monthly")
  updatedAt             DateTime @updatedAt
}

model Message {
  id        String   @id @default(cuid())
  content   String   @db.Text
  role      String   // "user" or "assistant"
  createdAt DateTime @default(now())
  userId    String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ContactMessage {
  id        String   @id @default(cuid())
  fullName  String
  email     String
  phone     String
  message   String   @db.Text
  createdAt DateTime @default(now())
}

// New chat-related models
model ChatConversation {
  id            String        @id @default(cuid())
  visitorId     String
  userId        String
  user          User         @relation(fields: [userId], references: [id])
  userAgent     String?
  deviceType    String?
  browser       String?
  os            String?
  ipAddress     String?
  referrer      String?
  firstSeen     DateTime      @default(now())
  lastSeen      DateTime      @updatedAt
  totalMessages Int           @default(0)
  avgResponseTime Float?
  messages      ChatMessage[]

  @@unique([visitorId, userId])
}

model ChatMessage {
  id             String          @id @default(cuid())
  conversationId String
  content        String
  role           String          // 'user' or 'assistant'
  createdAt      DateTime        @default(now())
  conversation   ChatConversation @relation(fields: [conversationId], references: [id])
}

model Document {
  id          String   @id @default(cuid())
  title       String
  content     String   @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  fileName     String
  originalName String
  fileType     String
  fileSize     Int
  category     String?
  description  String?  @db.Text
  keywords     String?  // Comma-separated list of keywords extracted from the document
  uploadedAt   DateTime @default(now())
  metadata     String?
  chunks       DocumentChunk[]
  
  @@index([userId])
  @@index([category])
  @@index([keywords])
}

model DocumentChunk {
  id          String   @id @default(cuid())
  documentId  String
  content     String   @db.Text
  chunkIndex  Int
  
  document    Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  embedding   Embedding?
  
  @@index([documentId])
}

model Embedding {
  id        String   @id @default(cuid())
  vector    Float[]  // Using array of floats instead of vector type
  chunkId   String   @unique
  userId    String
  chunk     DocumentChunk @relation(fields: [chunkId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([userId])
}

model Log {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  level     String
  message   String
  meta      Json?
  createdAt DateTime @default(now())
}

model QueryAnalytics {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  query       String
  response    String
  responseTime Int
  visitorId   String
  success     Boolean  @default(true)
  error       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
  @@index([visitorId])
  @@index([createdAt])
}

model VisitorSession {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  visitorId   String
  userAgent   String
  ipAddress   String
  startTime   DateTime
  endTime     DateTime
  duration    Int      // in seconds
  queries     Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
  @@index([visitorId])
  @@index([startTime])
}
