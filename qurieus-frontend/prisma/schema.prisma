// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

datasource db {
  provider          = "postgresql"
  url               = env("DATABASE_URL")
  shadowDatabaseUrl = env("SHADOW_DATABASE_URL") // Only needed when using a cloud provider that doesn't support the creation of new databases, like Heroku. Learn more: https://pris.ly/d/migrate-shadow
  extensions        = [vector]
}

generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
  previewFeatures = ["postgresqlExtensions"]
}

// Enums
enum SubscriptionType {
  TRIAL
  MONTHLY
  YEARLY
}

enum PlanType {
  FREE
  BASIC
  STANDARD
  PRO
  ENTERPRISE
}

enum UserRole {
  USER        @map("User")        /// Regular user with basic access
  ADMIN       @map("Admin")       /// Administrator with elevated privileges
  SUPER_ADMIN @map("Super Admin") /// Super administrator with full system access
  AGENT       @map("Agent")       /// Human agent for chat escalation
}



model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id                    String    @id @default(cuid())
  name                  String
  email                 String    @unique
  emailVerified         DateTime?
  image                 String?
  password              String?   // Optional for OAuth users (e.g. Google Sign-In)
  passwordResetToken    String?   @unique
  passwordResetTokenExp DateTime?
  role                  UserRole  @default(USER)
  
  // Profile fields
  company               String?
  plan                  PlanType?
  subscription_type     SubscriptionType?
  subscription_start_date DateTime? @default(now())
  subscription_end_date DateTime?
  is_active             Boolean   @default(true)
  is_verified           Boolean   @default(false)
  verification_token    String?   @unique
  verification_expires  DateTime?
  login_attempts        Int       @default(0)
  locked_until          DateTime?
  created_at            DateTime  @default(now())
  updated_at            DateTime  @updatedAt
  deleted_at            DateTime? // Soft delete - when set, user is considered deleted
  jobTitle              String?
  bio                   String?
  phone                 String?

  // Agent/owner relationship
  parentUserId          String?
  parentUser            User?     @relation("UserAgents", fields: [parentUserId], references: [id])
  agents                User[]    @relation("UserAgents")

  accounts              Account[]
  sessions              Session[]
  subscriptions         UserSubscription[] // one-to-many
  messages              Message[]
  documents             Document[]
  chatConversations     ChatConversation[]
  logs                  Log[]
  queries               QueryAnalytics[]
  visitorSessions       VisitorSession[]
  visitorInfo           VisitorInfo[] // one-to-many

  // Agent-related fields
  agent                 Agent?    // One-to-one relationship with Agent
  assignedChats         AgentChat[] @relation("AssignedAgent")
  createdTickets        SupportTicket[] @relation("TicketCreator")
  assignedTickets       SupportTicket[] @relation("TicketAssignee")
  agentMessages         ChatMessage[] @relation("AgentMessages")

  allowedOrigins        String[] @default([]) // e.g. ["https://mydomain.com"]
  allowedReferrers      String[] @default([]) // e.g. ["https://mydomain.com/page"]
  allowedIPs            String[] @default([]) // e.g. ["1.2.3.4"]

  trialExtensionRequests TrialExtensionRequest[]
  testimonials            Testimonial[]
  @@map("Users")
}

model TrialExtensionRequest {
  id              String    @id @default(cuid())
  userId          String
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userSubscriptionId String
  status          String    @default("PENDING") // PENDING, APPROVED, REJECTED
  requestedAt     DateTime  @default(now())
  extensionDays   Int       @default(7)
  newPeriodEnd    DateTime?
  approvedById    String?
  approvedAt      DateTime?
  rejectionReason String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model SubscriptionPlan {
  id          String   @id @default(cuid())
  name        String   @unique
  description String
  price       Float
  currency    String   @default("INR")
  features    String[]
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  subscriptions UserSubscription[]
  paddleConfig PaddleConfig?
  idealFor    String   // NEW: e.g. "Individuals", "Small Teams"
  keyLimits   String   // NEW: e.g. "5 docs · 10 MB · 25 queries/day"
  maxDocs     Int?
  maxStorageMB Int?
  maxQueriesPerDay Int?
}

model PaddleConfig {
  id                String   @id @default(cuid())
  subscriptionPlanId String  @unique
  productId         String
  priceId           String
  trialDays         Int      @default(0)
  billingCycle      String   @default("monthly")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  subscriptionPlan  SubscriptionPlan @relation(fields: [subscriptionPlanId], references: [id], onDelete: Cascade)
}

model UserSubscription {
  id                    String   @id @default(uuid())
  userId                String
  user                  User    @relation(fields: [userId], references: [id])
  planId                String
  plan                  SubscriptionPlan @relation(fields: [planId], references: [id])
  paddleSubscriptionId  String   @unique
  paddleCustomerId      String
  status                String
  currentPeriodStart    DateTime
  currentPeriodEnd      DateTime
  cancelledAt           DateTime?
  paddlePaymentId       String?
  paddlePaymentAmount   Float?
  paddlePaymentDate     DateTime?
  paddlePaymentError    String?
  paddlePaymentCurrency String?   @default("INR")
  startDate             DateTime @default(now())
  nextBillingDate       DateTime @default(now())
  createdAt             DateTime @default(now())
  billingCycle          String @default("monthly")
  updatedAt             DateTime @updatedAt
  planSnapshot          Json?   // Stores the plan details at the time of subscription for versioning
}

model Message {
  id        String   @id @default(cuid())
  content   String   @db.Text
  role      String   // "user" or "assistant"
  createdAt DateTime @default(now())
  userId    String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ContactMessage {
  id        String   @id @default(cuid())
  fullName  String
  email     String
  phone     String
  message   String   @db.Text
  createdAt DateTime @default(now())
}

enum TestimonialStatus {
  PENDING
  APPROVED
  REJECTED
}

model Testimonial {
  id              String           @id @default(cuid())
  userId          String
  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  content         String           @db.Text
  designation     String?          // e.g. "Founder @ Company"
  star            Int              @default(5)
  isApproved      Boolean          @default(false) // Kept for backward compat; sync with status
  status          TestimonialStatus @default(PENDING)
  rejectionReason String?          @db.Text       // Admin comment when rejecting (suggestions for user)
  rejectedAt      DateTime?
  rejectedById    String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@index([isApproved])
  @@index([userId])
  @@index([status])
}

// New chat-related models
model ChatConversation {
  id            String        @id @default(cuid())
  visitorId     String
  userId        String
  user          User         @relation(fields: [userId], references: [id])
  userAgent     String?
  deviceType    String?
  browser       String?
  os            String?
  ipAddress     String?
  referrer      String?
  firstSeen     DateTime      @default(now())
  lastSeen      DateTime      @updatedAt
  totalMessages Int           @default(0)
  avgResponseTime Float?
  messages      ChatMessage[]
  visitorInfo   VisitorInfo?  @relation(fields: [visitorId], references: [visitorId])

  // Agent escalation fields
  status        ChatStatus    @default(AI_CHAT)
  escalatedAt   DateTime?
  agentChat     AgentChat?
  escalationReason String?

  @@unique([visitorId, userId])
}

model ChatMessage {
  id             String          @id @default(cuid())
  conversationId String
  content        String
  role           String          // 'user' or 'assistant' or 'agent'
  createdAt      DateTime        @default(now())
  conversation   ChatConversation @relation(fields: [conversationId], references: [id])
  
  // Agent message fields
  agentId        String?
  agent          User?           @relation("AgentMessages", fields: [agentId], references: [id])
}

// New model for visitor information
model VisitorInfo {
  visitorId     String   @id
  name          String?
  email         String?
  phone         String?
  company       String?
  source        String?  // e.g., "chat_widget", "contact_form", "signup"
  firstSeen     DateTime @default(now())
  lastSeen      DateTime @updatedAt
  totalVisits   Int      @default(1)
  totalQueries  Int      @default(0)
  isConverted   Boolean  @default(false) // Whether they became a user
  convertedAt   DateTime?
  convertedUserId String?
  convertedUser User?    @relation(fields: [convertedUserId], references: [id])
  conversations ChatConversation[]
  sessions      VisitorSession[]
  analytics     QueryAnalytics[]
  tickets       SupportTicket[]
  
  @@index([email])
  @@index([firstSeen])
  @@index([isConverted])
}

model Document {
  id          String   @id @default(cuid())
  title       String
  content     String?  @db.Text  // Made optional since we'll extract it during processing
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  fileName     String
  originalName String
  fileType     String
  fileSize     Int
  category     String?
  description  String?  @db.Text
  keywords     String?  // Comma-separated list of keywords extracted from the document
  uploadedAt   DateTime @default(now())
  metadata     String?
  
  // S3 Integration
  fileUrl      String?  // S3 key for the uploaded file
  
  // Simple status system (like NestJS app)
  status       String   @default("DRAFT")  // DRAFT, REVIEW, APPROVED, FILED, ARCHIVED, PROCESSING, PROCESSED
  
  // AI Processing fields (simplified)
  aiDocumentId String?  // Document ID from AI service (FastAPI)
  
  // Qdrant/AI Integration fields
  qdrantDocumentId String?  // Document ID in Qdrant vector database
  chunkCount       Int      @default(0)  // Number of chunks created
  isProcessed      Boolean  @default(false)  // Whether document has been processed for embeddings
  processedAt      DateTime?  // When the document was processed
  
  // Relationships
  chunks          DocumentChunk[]
  
  @@index([userId])
  @@index([category])
  @@index([keywords])
  @@index([qdrantDocumentId])
  @@index([isProcessed])
  @@index([status])
  @@index([aiDocumentId])
}

model DocumentChunk {
  id              String   @id @default(cuid())
  documentId      String
  document        Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  
  // Chunk metadata
  chunkIndex      Int      // Order of the chunk in the document
  content         String   @db.Text  // The actual chunk content
  contentLength   Int      // Length of the chunk content
  
  // Qdrant integration
  qdrantPointId   String?  // Point ID in Qdrant vector database
  embeddingVector Float[]  // The embedding vector (if stored locally)
  
  // Processing metadata
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  @@index([documentId])
  @@index([chunkIndex])
  @@index([qdrantPointId])
  @@unique([documentId, chunkIndex])
}

model Log {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  level     String
  message   String
  meta      Json?
  createdAt DateTime @default(now())
}

model QueryAnalytics {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  query       String
  response    String
  responseTime Int
  visitorId   String
  visitorInfo VisitorInfo? @relation(fields: [visitorId], references: [visitorId])
  success     Boolean  @default(true)
  error       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
  @@index([visitorId])
  @@index([createdAt])
}

model VisitorSession {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  visitorId   String
  visitorInfo VisitorInfo? @relation(fields: [visitorId], references: [visitorId])
  userAgent   String
  ipAddress   String
  startTime   DateTime
  endTime     DateTime
  duration    Int      // in seconds
  queries     Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
  @@index([visitorId])
  @@index([startTime])
}

model PendingSubscription {
  id            String   @id @default(cuid())
  transactionId String   @unique
  userId        String
  createdAt     DateTime @default(now())
  // Optionally, add more fields as needed (e.g., planId, status)
}

// Site-wide config (e.g. default embed user for this website) - set by super admin
model SiteConfig {
  id        String   @id @default(cuid())
  key       String   @unique // e.g. "embed_user_id"
  value     String   @db.Text
  updatedAt DateTime @updatedAt
}

// Agent Management System
model Agent {
  id              String   @id @default(cuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // Agent profile
  displayName     String
  bio             String?
  avatar          String?
  specialties     String[] // e.g., ["technical", "billing", "general"]
  languages       String[] // e.g., ["en", "es", "fr"]
  
  // Agent status and availability
  isOnline        Boolean  @default(false)
  isAvailable     Boolean  @default(true)
  maxConcurrentChats Int   @default(5)
  currentChats    Int      @default(0)
  
  // Agent performance metrics
  totalChatsHandled Int    @default(0)
  avgResponseTime   Float?
  satisfactionRating Float?
  
  // Agent settings
  autoAcceptChats  Boolean @default(true)
  workingHours     Json?   // Store working hours as JSON
  timezone         String  @default("UTC")
  
  // Timestamps
  lastActiveAt     DateTime @default(now())
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  
  // Relationships
  
  @@index([isOnline, isAvailable])
  @@index([specialties])
}

model AgentChat {
  id              String   @id @default(cuid())
  conversationId  String   @unique
  conversation    ChatConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  
  // Agent assignment
  agentId         String
  agent           User     @relation("AssignedAgent", fields: [agentId], references: [id])
  
  // Chat status
  status          AgentChatStatus @default(ACTIVE)
  assignedAt      DateTime @default(now())
  startedAt       DateTime?
  endedAt         DateTime?
  
  // Chat metadata
  priority        ChatPriority @default(NORMAL)
  tags            String[] // e.g., ["urgent", "technical", "billing"]
  notes           String?  @db.Text
  
  // Performance tracking
  firstResponseTime Int?   // in seconds
  resolutionTime   Int?    // in seconds
  satisfactionRating Int?  // 1-5 scale
  
  @@index([agentId, status])
  @@index([status, priority])
}

model SupportTicket {
  id              String   @id @default(cuid())
  
  // Ticket details
  title           String
  description     String   @db.Text
  priority        TicketPriority @default(MEDIUM)
  status          TicketStatus @default(OPEN)
  category        String   // e.g., "technical", "billing", "general"
  
  // User information
  visitorId       String?
  visitorInfo     VisitorInfo? @relation(fields: [visitorId], references: [visitorId])
  
  // Assignment
  createdById     String?
  createdBy       User?    @relation("TicketCreator", fields: [createdById], references: [id])
  assignedToId    String?
  assignedTo      User?    @relation("TicketAssignee", fields: [assignedToId], references: [id])
  
  // Contact information
  contactName     String
  contactEmail    String
  contactPhone    String?
  
  // Timestamps
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  assignedAt      DateTime?
  resolvedAt      DateTime?
  closedAt        DateTime?
  
  // Ticket metadata
  source          String   @default("contact_form") // "contact_form", "chat_escalation", "email"
  tags            String[]
  notes           String?  @db.Text
  
  @@index([status, priority])
  @@index([assignedToId])
  @@index([createdAt])
}

// Enums for the new models
enum ChatStatus {
  AI_CHAT         @map("AI Chat")         /// Chat is being handled by AI
  ESCALATED       @map("Escalated")       /// Chat has been escalated to human agent
  RESOLVED        @map("Resolved")        /// Chat has been resolved
  CLOSED          @map("Closed")          /// Chat has been closed
}

enum AgentChatStatus {
  PENDING         @map("Pending")         /// Chat assigned but agent hasn't started
  ACTIVE          @map("Active")          /// Agent is actively handling the chat
  ON_HOLD         @map("On Hold")         /// Chat is on hold
  RESOLVED        @map("Resolved")        /// Chat has been resolved
  CLOSED          @map("Closed")          /// Chat has been closed
}

enum ChatPriority {
  LOW             @map("Low")             /// Low priority chat
  NORMAL          @map("Normal")          /// Normal priority chat
  HIGH            @map("High")            /// High priority chat
  URGENT          @map("Urgent")          /// Urgent priority chat
}

enum TicketPriority {
  LOW             @map("Low")             /// Low priority ticket
  MEDIUM          @map("Medium")          /// Medium priority ticket
  HIGH            @map("High")            /// High priority ticket
  URGENT          @map("Urgent")          /// Urgent priority ticket
}

enum TicketStatus {
  OPEN            @map("Open")            /// Ticket is open
  IN_PROGRESS     @map("In Progress")     /// Ticket is being worked on
  PENDING         @map("Pending")         /// Ticket is pending customer response
  RESOLVED        @map("Resolved")        /// Ticket has been resolved
  CLOSED          @map("Closed")          /// Ticket has been closed
}
