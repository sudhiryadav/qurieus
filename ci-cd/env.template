# Template for app-specific env files on server (/home/ubuntu/ or ENV_DIR)
# Files: prod.qurieus.frontend.env, prod.qurieus.backend.env, prod.qurieus.bot.env
#        staging.qurieus.frontend.env, staging.qurieus.backend.env, staging.qurieus.bot.env
# Replace placeholders with real values.

# === Frontend ===
PORT=8000
NODE_ENV=production
NEXTAUTH_URL=https://your-domain.com
NEXTAUTH_SECRET=your-secret
NEXT_PUBLIC_APP_URL=https://your-domain.com

# Database (Prisma)
DATABASE_URL="postgresql://user:password@host:5432/dbname"
SHADOW_DATABASE_URL="postgresql://user:password@host:5432/dbname_shadow"

# Backend
BACKEND_URL=https://your-domain.com
BACKEND_API_KEY=your-api-key

# Google Sign-In (OAuth)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Email - Google Workspace SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=admin@myflatmate.in
SMTP_PASSWORD=your-app-password
SMTP_SECURE=false

# Email configuration
# SMTP_FROM_EMAIL: From address for transactional emails (verification, password reset, etc.)
# Use no-reply@ for automated emails so users don't reply to them
SMTP_FROM_EMAIL=no-reply@qurieus.com
# ADMIN_EMAIL: Internal notifications (subscription confirmations, admin alerts)
ADMIN_EMAIL=hello@qurieus.com
# NEXT_PUBLIC_CONTACT_EMAIL: Where contact form submissions are sent
NEXT_PUBLIC_CONTACT_EMAIL=contact@qurieus.com
# NEXT_PUBLIC_SUPPORT_EMAIL: Shown in footer, FAQ, terms, refund policy, email templates
NEXT_PUBLIC_SUPPORT_EMAIL=support@qurieus.com
# NEXT_PUBLIC_SALES_EMAIL: For pricing/sales inquiries (optional)
NEXT_PUBLIC_SALES_EMAIL=sales@qurieus.com

# Paddle, Redis, Modal, Qdrant, S3, etc. - add all vars from frontend .env

# === Backend ===
ENVIRONMENT=production
FAST_API_HOST=127.0.0.1
FAST_API_PORT=8001
FRONTEND_URL=https://your-domain.com
AI_SERVICE_API_KEY=your-api-key
QDRANT_URL=...
QDRANT_COLLECTION=qurieus
QDRANT_API_KEY=...

# === Bot (Teams) ===
MICROSOFT_APP_ID=...
MICROSOFT_APP_PASSWORD=...
MICROSOFT_APP_TENANT_ID=...
